{
  "name": "gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Public API gateway. Single front door, session-based auth, proxies to internal services.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "http-proxy-middleware": "^3.0.0",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.4.1",
    "pino": "^9.1.0",
    "pino-http": "^9.0.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.52.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "rimraf": "^5.0.5",
    "vitest": "^1.6.0",
    "@types/express": "^4.17.21",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.12.7"
  }
}
