{
  "name": "auth-service",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication service. Clean Architecture + SOLID, DI via tsyringe.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:run:prod": "typeorm -d dist/infrastructure/database/data-source.js migration:run"
  },
  "dependencies": {
    "express": "^5.2.1",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "zod": "^3.23.8",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5",
    "typeorm": "^0.3.20",
    "glob": "^11.0.0",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "pino": "^9.1.0",
    "pino-http": "^9.0.0",
    "kafkajs": "^2.2.4",
    "dotenv": "^16.4.5",
    "tsyringe": "^4.8.0",
    "reflect-metadata": "^0.2.2",
    "express-rate-limit": "^8.5.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "rimraf": "^6.1.3",
    "eslint": "^9.10.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^1.6.0",
    "@testcontainers/postgresql": "^12.0.3",
    "testcontainers": "^10.13.0",
    "@types/express": "^5.0.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.8",
    "@types/pg": "^8.11.5",
    "@types/node": "^25.9.1"
  }
}
