# ===========================================================================
# Production env template — copy to `.env.prod` at the repo root and fill in.
#
#   cp infra/.env.prod.example .env.prod
#   make prod-config        # validate before deploying
#   make up-prod
#
# THIS FILE IS NOT THE SECRET STORE. The values marked REQUIRED below are
# secrets; their source of truth must be an external secret manager —
# HashiCorp Vault, AWS/GCP/Azure Secrets Manager, or Doppler — and the
# real `.env.prod` should be MATERIALIZED from it at deploy time (e.g.
# `doppler secrets download --format env`, `vault kv get -format=...`,
# or your CD pipeline writing the file just-in-time) and never committed.
# `.env.prod` must be in .gitignore and readable only by the deploy user.
#
# Password rule: DB/Redis passwords are embedded into URLs by the overlay
# (postgres://user:pass@host, redis://:pass@host). Keep them URL-safe —
# letters/digits/-_ only — or percent-encode reserved characters.
# `openssl rand -hex 32` output is always safe.
#
# Vars marked REQUIRED have no default in docker-compose.prod.yml: compose
# hard-fails (`${VAR:?...}`) if they are unset or empty.
# ===========================================================================

# ---- Network (docker) ----
PLATFORM_NETWORK=backend_platform

# ---- Edge (Caddy / TLS) ----
# Prod binds the real ports. Also swap infra/caddy/Caddyfile hostnames for
# your public DNS name so Caddy provisions Let's Encrypt certs.
CADDY_HTTPS_PORT=443
CADDY_HTTP_PORT=80

# ---- Kafka (3-broker KRaft cluster in prod) ----
# Topic replication — consumed by kafka-init (also set in the overlay;
# kept here so manual `kafka-topics.sh` runs agree with the cluster).
KAFKA_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2
# Full broker list; the overlay pins app services to this same value.
KAFKA_BROKERS_INTERNAL=kafka:9092,kafka-2:9092,kafka-3:9092
# No external listener in prod — Kafka is not reachable from the host.
KAFKA_BROKERS_EXTERNAL=

# ---- Redis ----
# REQUIRED — Redis runs with --requirepass. Generate: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME__openssl_rand_hex_32
# Base-file fallback URL; the overlay overrides every consumer with the
# authenticated redis://:${REDIS_PASSWORD}@redis:6379 form.
REDIS_URL_INTERNAL=redis://redis:6379

# ---- Postgres: auth ----
AUTH_DB_USER=auth
# REQUIRED — also feeds the backup sidecar and the service DATABASE_URL.
AUTH_DB_PASSWORD=CHANGE_ME__url_safe_password
AUTH_DB_NAME=auth
# Base-file fallback; the overlay rebuilds DATABASE_URL from the parts above.
AUTH_DATABASE_URL=

# ---- Postgres: ai-agents ----
AGENTS_DB_USER=agents
# REQUIRED
AGENTS_DB_PASSWORD=CHANGE_ME__url_safe_password
AGENTS_DB_NAME=agents
AGENTS_DATABASE_URL=

# ---- Gateway ----
# Public origin users hit (must match the Caddyfile hostname).
GATEWAY_PUBLIC_ORIGIN=https://app.example.com
# Comma-separated CORS allow-list — production frontend origins only.
FRONTEND_ORIGINS=https://app.example.com

# Internal URLs the gateway uses to reach services (docker DNS).
AUTH_SERVICE_URL=http://auth-service:3001
AI_AGENTS_SERVICE_URL=http://ai-agents-service:8000

# Resilience / rate-limit knobs
PROXY_CB_THRESHOLD=5
PROXY_CB_RESET_MS=15000
RATE_LIMIT_PER_MINUTE=120

# ---- Sessions ----
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=86400
# REQUIRED — 32+ byte random secret. Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME__openssl_rand_hex_32

# ---- Auth service ----
AUTH_PORT=3001
BCRYPT_ROUNDS=12
OUTBOX_POLL_INTERVAL_MS=1000

# ---- AI agents service ----
AGENTS_PORT=8000
# LiteLLM proxy (the active model provider) — treat the key as a secret.
LITELLM_PROXY_API_BASE=https://litellm.example.com
LITELLM_PROXY_API_KEY=CHANGE_ME__from_secret_store
LITELLM_MODEL=gpt-4o-mini
LITELLM_MASTER_KEY=
# Direct-provider keys — unused by the active agent (LiteLLM routes);
# leave blank unless a code path needs them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KAFKA_MAX_HANDLER_ATTEMPTS=3
# Vector store / embeddings
VECTOR_STORE_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=praxis_knowledge
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VECTOR_SIZE=1536
# LangSmith tracing (optional; key is a secret if set)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=praxis

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# REQUIRED — Grafana admin login (no admin/admin fallback in prod).
GRAFANA_ADMIN_USER=CHANGE_ME
GRAFANA_ADMIN_PASSWORD=CHANGE_ME__openssl_rand_hex_32
