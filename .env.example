# Copy to .env. These are sane local defaults; override per environment.

# ---- Network (docker) ----
PLATFORM_NETWORK=backend_platform

# ---- Edge (Caddy / TLS) ----
CADDY_HTTPS_PORT=8443
CADDY_HTTP_PORT=8888

# ---- Kafka ----
KAFKA_EXTERNAL_PORT=9094
KAFKA_BROKERS_INTERNAL=kafka:9092
KAFKA_BROKERS_EXTERNAL=localhost:9094

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL_INTERNAL=redis://redis:6379
REDIS_URL_EXTERNAL=redis://localhost:6379

# ---- Postgres: auth ----
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=auth
AUTH_DB_NAME=auth
AUTH_DB_PORT=5433
AUTH_DATABASE_URL=postgres://auth:auth@postgres-auth:5432/auth

# ---- Postgres: ai-agents ----
AGENTS_DB_USER=agents
AGENTS_DB_PASSWORD=agents
AGENTS_DB_NAME=agents
AGENTS_DB_PORT=5434
AGENTS_DATABASE_URL=postgres://agents:agents@postgres-agents:5432/agents

# ---- Gateway ----
GATEWAY_PORT=4000
GATEWAY_PUBLIC_ORIGIN=https://localhost:8443
# Comma-separated list of allowed CORS origins.
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost:5173

# Internal URLs the gateway uses to reach services
AUTH_SERVICE_URL=http://auth-service:3001
AI_AGENTS_SERVICE_URL=http://ai-agents-service:8000

# Resilience / rate-limit knobs
PROXY_CB_THRESHOLD=5
PROXY_CB_RESET_MS=15000
RATE_LIMIT_PER_MINUTE=120

# ---- Sessions ----
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=86400
# Required: random 32+ byte secret. Generate with `openssl rand -hex 32`.
SESSION_SECRET=change-me-please-generate-a-real-secret

# ---- Auth service ----
AUTH_PORT=3001
BCRYPT_ROUNDS=12
# How often the outbox poller flushes pending events to Kafka.
OUTBOX_POLL_INTERVAL_MS=1000
# Failed publishes are retried up to this many times, then the row is parked
# (dead_at set, skipped by the poller; NULL dead_at to re-queue it).
OUTBOX_MAX_ATTEMPTS=10

# ---- AI agents service ----
AGENTS_PORT=8000

# ---- Sandbox service ----
# Backend for the project sandbox (Start Sandbox / agent sandbox tools):
#   local (default) — runs each sandbox as a Docker container on your host
#                     daemon. No account/key needed. DEV-ONLY: the service
#                     mounts the docker socket (root-on-host access).
#   e2b             — E2B cloud desktop sandboxes; needs E2B_API_KEY below
#                     and adds a live VNC desktop stream.
SANDBOX_PROVIDER=local
# Base image for local sandboxes. Default bundles a minimal X desktop
# (built by the sandbox-desktop-image compose service) so the Sandbox tab
# shows a live screenshot stream. Any POSIX-shell image works for the
# agent's command/file tools.
LOCAL_SANDBOX_IMAGE=praxis-sandbox-desktop:local
# Sandbox container runtime. Empty = Docker default (runc). Set to
# "sysbox-runc" — AFTER installing Sysbox on the host — to run each sandbox
# unprivileged yet able to run nested docker / docker compose.
SANDBOX_RUNTIME=
# Only needed when SANDBOX_PROVIDER=e2b. Get a key from
# https://e2b.dev/dashboard?tab=keys — format: e2b_<hex>.
E2B_API_KEY=

# ---- Memory service ----
MEMORY_PORT=8001
MEMORY_SERVICE_URL=http://memory-service:8001
MEMORY_SERVICE_MCP_URL=http://memory-service:8001/mcp
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_PASSWORD=changeme                 # change in prod
GRAPHITI_LLM_MODEL=gpt-4.1-mini        # model used for entity extraction
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Max times the Kafka consumer retries a handler before sending to DLQ.
KAFKA_MAX_HANDLER_ATTEMPTS=3

# ---- Observability ----
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3030
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
JAEGER_UI_PORT=16686
KAFKA_UI_PORT=8080
LOKI_PORT=3100
